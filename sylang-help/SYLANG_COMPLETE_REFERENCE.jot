    text "correlate type <nodetype> via <relationship> reverse"

  def paragraph cso18dhi
    text "**Use Cases:**"

  def list ofw9ur9u
    listtype bulleted
    def listitem vjpk2xfc
      text "Find all requirements satisfied by a specific test"
    def listitem e0q1vpw2
      text "Find all functions that implement requirements"
    def listitem wmtykn2y
      text "Impact analysis: "What references this symbol?""

  def paragraph u4qml69v
    text "**Examples:**"

  def code f4jyvmph
    language "sylang"
    text """# Forward: Find tests that satisfy requirements
sourcetype requirement
correlate type testcase via satisfies forward  # or just 'forward' (default)

# Reverse: Find requirements that ARE satisfied by tests
sourcetype testcase
correlate type requirement via satisfies reverse"""

