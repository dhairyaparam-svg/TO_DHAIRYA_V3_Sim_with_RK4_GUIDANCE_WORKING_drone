  def code 1zs41v6p
    language "sylang"
    text """def chart <identifier>
  name "Chart Name"
  type bar|line|pie|scatter|gauge|sankey
  sourcetype <nodetype> [where <conditions>]
  [correlate type <nodetype> via <relationship>]
  [analyze <status>]
  [groupby <property>]
  [orderby <property> [asc|desc]]
  [xaxis "Label"]
  [yaxis "Label"]
  [span <rows>x<columns>]"""

  def paragraph ch785isc
    text "**Chart Types:**"

  def list kcta6wr3
    listtype bulleted
    def listitem zq51c1s8
      text "`bar` - Bar chart"
    def listitem m28rtf71
      text "`line` - Line chart"
