  def heading 0ei3hqug
    text "Validation Rules"
    level 2

  def paragraph mmlq37iz
    text """✅ Exactly one `hdef interfaceset` per file
✅ Multiple `def operation/signal/datatype/parameter` allowed  
✅ Operations and signals can reference datatypes via `requires`  
✅ Parameters can have `value` property  
✅ Can use `when ref config` for conditional visibility  
✅ Interfaces are referenced by blocks via `needs`/`provides`  
✅ Interfaces are referenced by functions via `needs`/`provides`  
✅ Interfaces are referenced by features via `needs`/`offers`  
❌ No hierarchical definitions (flat structure only)"""

  def heading 4t25fb8g
    text "Relationships"
    level 2

  def heading 5khfitpo
    text "InterfaceSet Level (hdef interfaceset)"
    level 3

  def list 0m7t982r
    listtype bulleted
    def listitem ebqlh2yp
      text "`decomposedfrom ref interfaceset` - Bottom-up interface composition (single only)"
    def listitem 32c244lb
      text "`decomposesto ref interfaceset` - Top-down interface breakdown (multiple allowed)"
    def listitem 352sv3tn
      text "`allocatedto ref block` - Interface allocated to specific block (single only)"

  def heading 25rlld23
    text "Definition Level (def operation/signal/datatype/parameter)"
