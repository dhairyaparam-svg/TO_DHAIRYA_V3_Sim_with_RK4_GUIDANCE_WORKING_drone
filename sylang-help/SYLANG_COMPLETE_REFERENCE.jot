  def heading d937vitn
    text "1. Metric Widget"
    level 3

  def paragraph druq85dv
    text "Display a single numeric value with optional unit."

  def paragraph tw8g77e7
    text "**Syntax:**"

  def code zm37voiq
    language "sylang"
    text """def metric <identifier>
  name "Metric Name"
  type count|percentage|sum|avg|min|max|gauge
  sourcetype <nodetype> [where <conditions>]
  [property <property_name>]
  [span <rows>x<columns>]"""

  def paragraph wsxbzii8
    text "**Metric Types:**"

  def list n39gn3a9
    listtype bulleted
    def listitem 5upzgyrx
      text "`count` - Count symbols"
    def listitem 4xp3ugll
      text "`percentage` - Calculate percentage (requires `correlate`)"
    def listitem ym5sv5ky
      text "`sum` - Sum numeric property"
    def listitem zca5j3u2
      text "`avg` - Average numeric property"
    def listitem ayfam2yk
      text "`min` - Minimum numeric property"
    def listitem 7ia1wk53
      text "`max` - Maximum numeric property"
    def listitem cuvm0bsc
      text "`gauge` - Display as gauge (0-100)"

  def paragraph uxfuiis7
    text "**Examples:**"

  def code 8q8a3frr
    language "sylang"
    text """# Simple count
def metric TOTAL_REQUIREMENTS
  name "Total Requirements"
  type count
  sourcetype requirement

# Count with filter
def metric APPROVED_REQUIREMENTS
  name "Approved Requirements"
  type count
  sourcetype requirement where status = approved

# Coverage percentage
def metric TEST_COVERAGE
  name "Test Coverage"
  type percentage
  sourcetype requirement where status = approved
  correlate type testcase via satisfies

# Average (requires property)
def metric AVG_PRIORITY
  name "Average Priority"
  type avg
  sourcetype requirement
  property priority"""

